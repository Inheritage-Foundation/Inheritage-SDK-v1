{
  "name": "@inheritage-foundation/sdk",
  "version": "0.3.0",
  "description": "Official TypeScript SDK for Inheritage API — Access 5000+ Indian heritage sites with React hooks, AI embeddings, GeoJSON, CIDOC-CRM, LIDO XML, OAI-PMH, and LangChain integration. Production-ready, type-safe, CC BY 4.0 compliant.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./langchain": {
      "import": "./dist/langchain.mjs",
      "require": "./dist/langchain.cjs",
      "types": "./dist/langchain.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks.mjs",
      "require": "./dist/hooks.cjs",
      "types": "./dist/hooks.d.ts"
    },
    "./components": {
      "import": "./dist/components/InheritageCitation.mjs",
      "require": "./dist/components/InheritageCitation.cjs",
      "types": "./dist/components/InheritageCitation.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/client.test.ts tests/langchain.test.ts",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "keywords": [
    "inheritage",
    "heritage",
    "india",
    "cultural-heritage",
    "temples",
    "monuments",
    "open-data",
    "digital-heritage",
    "cultural-preservation",
    "api",
    "sdk",
    "typescript",
    "react",
    "hooks",
    "geojson",
    "ai",
    "embeddings",
    "langchain",
    "openapi",
    "cidoc-crm",
    "lido",
    "oai-pmh",
    "sparql",
    "cc-by",
    "creative-commons"
  ],
  "author": "Ayush Mishra <hello@inheritage.foundation> (https://ayush.studio)",
  "contributors": [
    "Team Inheritage <hello@inheritage.foundation>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Inheritage-Foundation/Inheritage-SDK-v1.git"
  },
  "bugs": {
    "url": "https://github.com/Inheritage-Foundation/Inheritage-SDK-v1/issues"
  },
  "homepage": "https://www.inheritage.foundation/docs/api",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "langchain": "^0.3.14",
    "langsmith": "^0.3.7"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@tsconfig/node18": "^18.2.2",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "react": "^19.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  },
  "funding": "https://www.inheritage.foundation/donate"
}
